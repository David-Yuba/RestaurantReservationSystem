@page
@model ReservationSys_LaMaisonRestaurant.Pages.ReservationDetailsModel

@{
    ViewData["Title"] = "ReservationDetails";
}
<div class="page">
    <h1>Reservation</h1>
    <form method="post" class="details-display">
        <div class="form-field">
            <h5 class="form-label">
                @Html.DisplayNameFor(model => model.Reservation.ReferenceCode)
            </h5>
            <p class="form-data">
                @Html.DisplayFor(model => model.Reservation.ReferenceCode)
            </p>
        </div>
        <div class="form-field">
            <h5 class="form-label">
                @Html.DisplayNameFor(model => model.Reservation.FullName)
            </h5>
            <p class="form-data">
                @Html.DisplayFor(model => model.Reservation.FullName)
            </p>
        </div>
        <div class="form-field">
            <h5 class="form-label">
                @Html.DisplayNameFor(model => model.Reservation.Email)
            </h5>
            <p class="form-data">
                @Html.DisplayFor(model => model.Reservation.Email)
            </p>
        </div>
        <div class="form-field">
            <h5 class="form-label">
                @Html.DisplayNameFor(model => model.Reservation.PhoneNumber)
            </h5>
            <p class="form-data">
                @Html.DisplayFor(model => model.Reservation.PhoneNumber)
            </p>
        </div>
        <div class="form-field">
            <h5 class="form-label">
                @Html.DisplayNameFor(model => model.Reservation.Date)
            </h5>
            <p class="form-data">
                @Html.DisplayFor(model => model.Reservation.Date)
            </p>
        </div>
        <div class="form-field">
            <h5 class="form-label">
                @Html.DisplayNameFor(model => model.Reservation.TimeSlot)
            </h5>
            <p class="form-data">
                @Html.DisplayFor(model => model.Reservation.TimeSlot)
            </p>
        </div>
        <div class="form-field">
            <h5 class="form-label">
                @Html.DisplayNameFor(model => model.Reservation.PartySize)
            </h5>
            <p class="form-data">
                @Html.DisplayFor(model => model.Reservation.PartySize)
            </p>
        </div>
        <div class="form-field">
            <h5 class="form-label">
                @Html.DisplayNameFor(model => model.Reservation.SpecialRequest)
            </h5>
            <p class="form-data">
                @Html.DisplayFor(model => model.Reservation.SpecialRequest)
            </p>
        </div>
        <div class="form-field">
            <h5 class="form-label">
                @Html.DisplayNameFor(model => model.Reservation.Status)
            </h5>
            <select asp-for="Reservation.Status">
                <option value="Pending">Pending</option>
                <option value="Confirmed">Confirmed</option>
                <option value="Cancelled">Cancelled</option>
                <option value="Completed">Completed</option>
            </select>
        </div>
        <div class="form-field">
            <input type="submit" value="Apply changes"/>
        </div>
    </form>
    <div>
        <a asp-page="./Admin">Back to Reservation list</a>
    </div>
</div>