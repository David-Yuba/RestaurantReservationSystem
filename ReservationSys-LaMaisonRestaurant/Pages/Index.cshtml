@page
@model IndexModel

@{
    ViewData["Title"] = Model.RestaurantInfo.Name;
    ViewData["Name"] = Model.RestaurantInfo.Name;
}
<div class = "page">
    <h1>Create a Reservation</h1>
    <form method="post" asp-page="Index" class="create-form" onsubmit="reformatData(event)">
        <div asp-validation-summary="ModelOnly"></div>
        <div class="form-field create-form-field">
            <label asp-for="Reservation.FullName" class="form-label"></label>
            <input asp-for="Reservation.FullName" class="form-data" aria-required="true" />
            <span asp-validation-for="Reservation.FullName"></span>
        </div>
        <div class="form-field create-form-field">
            <label asp-for="Reservation.Email" class="form-label"></label>
            <input asp-for="Reservation.Email" class="form-data" aria-required="true" />
            <span asp-validation-for="Reservation.Email"></span>
        </div>
        <div class="form-field create-form-field">
            <label asp-for="Reservation.PhoneNumber" class="form-label"></label>
            <input asp-for="Reservation.PhoneNumber" class="form-data" aria-required="true" />
            <span asp-validation-for="Reservation.PhoneNumber"></span>
        </div>
        <div class="form-field create-form-field private-dining-field hidden">
            <label asp-for="Reservation.IsPrivateDining" class="form-label"></label>
            <input asp-for="Reservation.IsPrivateDining" class="form-data private-dining-input" 
                   oninput="onPrivateDiningInput()" />
            <span asp-validation-for="Reservation.IsPrivateDining"></span>
        </div>
        <div class="form-field create-form-field">
            <label asp-for="Reservation.PartySize" class="form-label"></label>
            <input asp-for="Reservation.PartySize" class="form-data party-size-input" 
                   oninput="onPartySizeInput(event)" />
            <span asp-validation-for="Reservation.PartySize"></span>
        </div>
        <div class="form-field create-form-field">
            <label asp-for="Reservation.Date" class="form-label"></label>
            <input asp-for="Reservation.Date" class="form-data date-input-field" autocomplete="off"
                   onfocus="onDateInputFocus(event)" onblur="onDateInputBlur(event)" oninput="onDateInput(event)"/>
            <span asp-validation-for="Reservation.Date" ></span>
        </div>
        <div class="form-field create-form-field">
            <label asp-for="Reservation.TimeSlot" class="form-label"></label>
            <select asp-for="Reservation.TimeSlot" class="form-data time-slot-input" oninput="onTimeSlotInput(event)">
                <option value="">Select time</option>
@{
    TimeOnly startTime = Model.RestaurantInfo.OpeningHours;
    TimeOnly endTime = Model.RestaurantInfo.ClosingHours;
    
    // Populates the options for all possible timeslots
    for (TimeOnly i=startTime ; i < endTime.Add(-Model.RestaurantInfo.ReservationSlotIncrements) ; i = i.Add(Model.RestaurantInfo.ReservationSlotIncrements)){
                <option value="@(i.ToString("HH:mm"))" class="time-slot-option">@(i.ToString("HH:mm"))</option>
    }
}
            </select>
            <span asp-validation-for="Reservation.TimeSlot"></span>
        </div>
        <div class="form-field create-form-field textarea-form-field">
            <label asp-for="Reservation.SpecialRequest" class="form-label"></label>
            <textarea asp-for="Reservation.SpecialRequest" maxlength="500" class="form-data" rows="5"></textarea>
            <span asp-validation-for="Reservation.SpecialRequest"></span>
        </div>
        <div class="form-field create-form-field" style="display: none;">
            <input asp-for="Reservation.ReferenceCode" class="form-data" value="defaultValue" />
        </div>
        <div class="form-field create-form-field" style="display: none;">
            <input asp-for="Reservation.Status" class="form-data" value="Pending"/>
        </div>
        <div class="form-field create-form-field">
            <input type="submit" value="Create"/>
        </div>
    </form>
    <div class="date-table" onclick="onDateDayClick(event)">
@{
    DateTime today = DateTime.Now;
        // Gets the current month and year
        <div tabindex="0" class="month-year" month-year>@today.ToString("MMMM") - @today.Year</div>
}
        <div class="date-table-days">
            <div tabindex="0" class="day-name" day-name>Mo</div>
            <div tabindex="0" class="day-name" day-name>Tu</div>
            <div tabindex="0" class="day-name" day-name>We</div>
            <div tabindex="0" class="day-name" day-name>Th</div>
            <div tabindex="0" class="day-name" day-name>Fr</div>
            <div tabindex="0" class="day-name" day-name>Sa</div>
            <div tabindex="0" class="day-name" day-name>Su</div>
@{
    DateOnly todaysDate = DateOnly.FromDateTime(DateTime.Now);
    // Fills the start of the table with empty divs to maintains alignment with day names
    for(DayOfWeek i=DayOfWeek.Monday ; i < (todaysDate.DayOfWeek != DayOfWeek.Sunday ? todaysDate.DayOfWeek : DayOfWeek.Saturday + 1) ; i++) {
            <div tabindex="0" class="day-name" day-name></div>
    }
    // Fills the table with the 30 days into the future
    for (int i=0 ; i<30 ; i++){
                    <div tabindex="0" date-value="@(todaysDate.ToString("dd-MM-yy"))">@(todaysDate.Day)</div>
        todaysDate = todaysDate.AddDays(1);
    }
}
        </div>
        <div></div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
